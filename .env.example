# Salesforce REST API integration using OAuth JWT bearer flow.
# Upload the public certificate to the Salesforce External Client App, then run
# requests as a Salesforce user with access to create Lead records.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_USERNAME=
# Local development uses salesforce/jwt/ai-readiness.key when this is empty.
# Hosted environments should set the private key value with newlines escaped as \n.
SALESFORCE_JWT_PRIVATE_KEY=

# Optional Salesforce settings.
SALESFORCE_API_VERSION=v60.0
SALESFORCE_LEAD_SOURCE=AI Readiness Assessment
SALESFORCE_LEAD_RECORD_TYPE_ID=
SALESFORCE_ASSESSMENT_TASK_SUBJECT=AI Readiness Assessment Completed

# Anthropic assessment agent.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
